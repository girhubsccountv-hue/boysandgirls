-- Variables
local spamActive = false
local spamCoroutine = nil
local currentText = ""
local customLines = {}

-- Function to split text into words
local function getWords(line)
    local words = {}
    for word in string.gmatch(line, "%S+") do
        table.insert(words, word)
    end
    return words
end

-- Function to rename pet with specific text
local function renamePet(text)
    petRenameRequest:FireServer(text)
end

-- Function to spam rename word by word
local function spamRenameWords(line)
    local words = getWords(line)
    local accumulatedText = ""
    
    for i = 1, #words do
        if not spamActive then break end
        
        if i == 1 then
            accumulatedText = words[i]
        else
            accumulatedText = accumulatedText .. " " .. words[i]
        end
        
        renamePet(accumulatedText)
        wait(0.1)
    end
end

-- Function to spam rename entire lines
local function spamRenameLines()
    while spamActive do
        for _, line in ipairs(customLines) do
            if not spamActive then break end
            renamePet(line)
            wait(0.5) -- Wait between lines
        end
        if spamActive then
            wait(1) -- Wait before repeating all lines
        end
    end
end

-- Function to start spamming
local function startSpam(mode, data)
    if spamCoroutine then
        pcall(function() coroutine.close(spamCoroutine) end)
    end
    
    spamActive = true
    
    if mode == "words" then
        spamCoroutine = coroutine.create(function()
            while spamActive do
                spamRenameWords(data)
                if spamActive then wait(0.5) end
            end
        end)
    elseif mode == "lines" then
        spamCoroutine = coroutine.create(function()
            spamRenameLines()
        end)
    end
    
    coroutine.resume(spamCoroutine)
end

-- Function to stop spamming
local function stopSpam()
    spamActive = false
    if spamCoroutine then
        pcall(function() coroutine.close(spamCoroutine) end)
        spamCoroutine = nil
    end
end

