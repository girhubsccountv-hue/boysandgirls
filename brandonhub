-- Command Bot Variables
local selectedCommandUser = nil
local isGivingCommands = false
local commandListener = nil
local currentKillTarget = nil
local isKilling = false
local killLoop = nil
local isFixing = false
local fixTimer = nil
local currentSelectedName = ""
local isStopped = false
local stopLoop = nil

-- Get chat channel
local function getChatChannel()
    local channel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
    return channel
end

-- Send message function
local function sendMessage(message)
    local channel = getChatChannel()
    if channel then
        channel:SendAsync(message)
    end
end

-- Function to find player by partial name or display name
local function findPlayerByName(input)
    input = input:lower()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- Check real username
            if player.Name:lower():sub(1, #input) == input then
                return player
            end
            -- Check display name
            if player.DisplayName and player.DisplayName:lower():sub(1, #input) == input then
                return player
            end
            -- Check if input is contained in name
            if player.Name:lower():match(input) then
                return player
            end
            if player.DisplayName and player.DisplayName:lower():match(input) then
                return player
            end
        end
    end
    return nil
end

-- Function to start stop teleporting (spam teleport to 52,20,24)
local function startStopTeleport()
    -- Stop any current kill loops
    if killLoop then
        killLoop:Disconnect()
        killLoop = nil
    end
    isKilling = false
    currentKillTarget = nil
    
    if stopLoop then
        stopLoop:Disconnect()
        stopLoop = nil
    end
    
    isStopped = true
    
    -- Start spam teleporting to fix location
    stopLoop = RunService.Heartbeat:Connect(function()
        if not isStopped then
            if stopLoop then stopLoop:Disconnect() end
            return
        end
        
        -- Get local character
        local localCharacter = LocalPlayer.Character
        if not localCharacter then
            return
        end
        
        local localHRP = localCharacter:FindFirstChild("HumanoidRootPart")
        if not localHRP then
            return
        end
        
        -- Teleport to fix location
        localHRP.CFrame = CFrame.new(52, 20, 24)
        
        -- Wait 0.01 seconds
        task.wait(0.01)
    end)
end

-- Function to stop current kill
local function stopKill()
    if killLoop then
        killLoop:Disconnect()
        killLoop = nil
    end
    isKilling = false
    currentKillTarget = nil
end

-- Function to stop stop teleporting
local function stopStopTeleport()
    if stopLoop then
        stopLoop:Disconnect()
        stopLoop = nil
    end
    isStopped = false
end

-- Function to start killing a player
local function startKilling(targetPlayer)
    -- Stop any current stop teleporting
    stopStopTeleport()
    
    -- Stop any current killing
    stopKill()
    
    if not targetPlayer or not targetPlayer.Character then
        return false
    end
    
    isKilling = true
    currentKillTarget = targetPlayer
    
    -- Start teleport loop
    killLoop = RunService.Heartbeat:Connect(function()
        if not isKilling or not currentKillTarget then
            if killLoop then killLoop:Disconnect() end
            return
        end
        
        -- Check if target still exists and has character
        if not currentKillTarget or not currentKillTarget.Parent then
            stopKill()
            return
        end
        
        local targetCharacter = currentKillTarget.Character
        if not targetCharacter then
            return
        end
        
        -- Check if target is dead
        local targetHumanoid = targetCharacter:FindFirstChild("Humanoid")
        if targetHumanoid and targetHumanoid.Health <= 0 then
            -- Target is dead, teleport to respawn location
            local localCharacter = LocalPlayer.Character
            if localCharacter then
                local localHRP = localCharacter:FindFirstChild("HumanoidRootPart")
                if localHRP then
                    localHRP.CFrame = CFrame.new(52, 20, 24)
                end
            end
            return
        end
        
        -- Get target's humanoidrootpart
        local targetHRP = targetCharacter:FindFirstChild("HumanoidRootPart")
        if not targetHRP then
            return
        end
        
        -- Get local character
        local localCharacter = LocalPlayer.Character
        if not localCharacter then
            return
        end
        
        local localHRP = localCharacter:FindFirstChild("HumanoidRootPart")
        if not localHRP then
            return
        end
        
        -- Teleport inside target
        local targetPos = targetHRP.Position
        localHRP.CFrame = CFrame.new(targetPos)
        
        -- Wait 0.01 seconds
        task.wait(0.01)
    end)
    
    return true
end

-- Function to handle fix command
local function handleFix()
    if isFixing then return end
    
    isFixing = true
    
    -- Stop any current stop teleporting
    stopStopTeleport()
    
    -- Stop any current killing
    local wasKilling = isKilling
    local killedTarget = currentKillTarget
    
    stopKill()
    
    -- Teleport to fix location once
    local localCharacter = LocalPlayer.Character
    if localCharacter then
        local localHRP = localCharacter:FindFirstChild("HumanoidRootPart")
        if localHRP then
            localHRP.CFrame = CFrame.new(52, 20, 24)
        end
    end
    
    -- Send fix message
    sendMessage("[] Fixing Bot")
    
    -- After 1 second, resume killing if there was a target
    if fixTimer then
        fixTimer:Disconnect()
    end
    
    fixTimer = game:GetService("Timers"):After(1, function()
        isFixing = false
        if wasKilling and killedTarget and killedTarget.Parent then
            -- Resume killing the previous target
            startKilling(killedTarget)
        end
        fixTimer = nil
    end)
end

-- Function to handle stop command
local function handleStop()
    -- Stop any current killing
    if isKilling and currentKillTarget then
        local targetName = currentKillTarget.Name
        stopKill()
        sendMessage("[+] Stopped Killing " .. targetName)
    end
    
    -- Start spam teleporting to fix location
    startStopTeleport()
end

-- Function to handle kill command
local function handleKillCommand(args, sender)
    if not args or args == "" then
        return
    end
    
    local targetName = args
    local targetPlayer = findPlayerByName(targetName)
    
    if not targetPlayer then
        sendMessage("[-] Player not found: " .. targetName)
        return
    end
    
    -- Check if already killing someone
    if isKilling and currentKillTarget then
        sendMessage("[-] Killing another user currently")
        return
    end
    
    -- Stop stop teleporting if active
    stopStopTeleport()
    
    -- Start killing the target
    if startKilling(targetPlayer) then
        sendMessage("[+] Killing " .. targetPlayer.Name)
    else
        sendMessage("[-] Failed to kill " .. targetPlayer.Name)
    end
end

-- Function to start listening to selected user's messages
local function startListening()
    if commandListener then
        commandListener:Disconnect()
    end
    
    if not selectedCommandUser then
        return
    end
    
    -- Listen for messages from the selected user
    commandListener = TextChatService.MessageReceived:Connect(function(message)
        -- Check if message is from selected user
        if message.TextSource and message.TextSource.Name == selectedCommandUser.Name then
            local text = message.Text
            
            -- Check for .kill command
            if text:lower():match("^%.kill") then
                local args = text:lower():gsub("%.kill", ""):gsub("^%s+", "")
                handleKillCommand(args, selectedCommandUser)
            end
            
            -- Check for .fix command
            if text:lower() == ".fix" then
                handleFix()
            end
            
            -- Check for .stop command
            if text:lower() == ".stop" then
                handleStop()
            end
        end
    end)
end

-- Function to stop listening
local function stopListening()
    if commandListener then
        commandListener:Disconnect()
        commandListener = nil
    end
end

