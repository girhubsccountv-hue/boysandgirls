local function getRemote()
    local eventSystem = ReplicatedStorage:FindFirstChild("EventInviteSystem")
    if not eventSystem then return nil end
    return eventSystem:FindFirstChild("EventTeleportEvent")
end

local function handleGrab()
    if not autoEnabled or isProcessing then return end
    local remote = getRemote()
    if not remote then return end

    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    isProcessing = true
    local originalCFrame = root.CFrame
    remote:FireServer()
    task.wait(0.2)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = originalCFrame
    end
    isProcessing = false
end

