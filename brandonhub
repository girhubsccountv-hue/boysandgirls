-- Function to get character and humanoid
local function getTargetCharacter(targetPlayer)
    if not targetPlayer then return nil, nil end
    
    local character = targetPlayer.Character
    if not character or not character.Parent then return nil, nil end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return nil, nil end
    
    return character, humanoid
end

-- Function to invoke the remote
local function invokeRemote(targetCharacter, targetHumanoid)
    if not targetCharacter or not targetHumanoid then return false end
    
    local success = pcall(function()
        local packages = replicatedStorage:FindFirstChild("Packages")
        if not packages then return end
        
        local knit = packages:FindFirstChild("Knit")
        if not knit then return end
        
        local services = knit:FindFirstChild("Services")
        if not services then return end
        
        local combatService = services:FindFirstChild("CombatService")
        if not combatService then return end
        
        local rf = combatService:FindFirstChild("RF")
        if not rf then return end
        
        local hitRemote = rf:FindFirstChild("Hit")
        if not hitRemote then return end
        
        local args = {
            targetCharacter,
            targetHumanoid,
            Vector3.new(107.95883178710938, 3.528562545776367, 18.3253231048584)
        }
        
        hitRemote:InvokeServer(unpack(args))
    end)
    
    return success
end

