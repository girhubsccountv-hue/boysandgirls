    if not enabled then return end
    if not canTrigger then return end
    
    local char = player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    if not isRagdolled(humanoid) then return end   -- sanity check
    
    canTrigger = false
    
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local originalCF = rootPart.CFrame
    
    -- Teleport to target position
    rootPart.CFrame = CFrame.new(TARGET_POS)
    task.wait(DELAY)
    
    -- Teleport back to original position + offset up
    if rootPart and rootPart.Parent then
        local returnPos = originalCF.Position + OFFSET_UP
        rootPart.CFrame = CFrame.new(returnPos) * CFrame.Angles(0, originalCF:toEulerAnglesYXZ(), 0)
    end
    
    -- Wait until ragdoll ends to allow next trigger
    local function onStateChanged(oldState, newState)
        if not isRagdolled(humanoid) then
            canTrigger = true
            ragdollConnection:Disconnect()
            ragdollConnection = nil
        end
    end
    
    if ragdollConnection then ragdollConnection:Disconnect() end
    ragdollConnection = humanoid.StateChanged:Connect(onStateChanged)
end

local function startDetection()
    -- Wait for character to exist
    local char = player.Character
    if not char then
        player.CharacterAdded:Wait()
        char = player.Character
    end
    
    local humanoid = char:WaitForChild("Humanoid")
    
    -- Listen for state changes to detect when ragdoll starts
    humanoid.StateChanged:Connect(function(oldState, newState)
        if not enabled then return end
        local newIsRagdoll = (newState == Enum.HumanoidStateType.Physics or humanoid.PlatformStand)
        local oldIsRagdoll = (oldState == Enum.HumanoidStateType.Physics or humanoid.PlatformStand)
        
        if newIsRagdoll and not oldIsRagdoll then
            onRagdollStarted()
        end
    end)
    
    -- Also handle character respawns
    player.CharacterAdded:Connect(function(newChar)
        local newHum = newChar:WaitForChild("Humanoid")
        canTrigger = true
        if ragdollConnection then
            ragdollConnection:Disconnect()
            ragdollConnection = nil
        end
        -- Reconnect state listener for new character
        newHum.StateChanged:Connect(function(oldState, newState)
            if not enabled then return end
            local newIsRagdoll = (newState == Enum.HumanoidStateType.Physics or newHum.PlatformStand)
            local oldIsRagdoll = (oldState == Enum.HumanoidStateType.Physics or newHum.PlatformStand)
            if newIsRagdoll and not oldIsRagdoll then
                onRagdollStarted()
            end
        end)
    end)
end

local function stopDetection()
    -- Nothing to clean up besides connections, but we keep them disabled
    enabled = false
    canTrigger = true
    if ragdollConnection then
        ragdollConnection:Disconnect()
        ragdollConnection = nil
    end
end

