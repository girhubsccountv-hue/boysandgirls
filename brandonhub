-- Variables
local player = game.Players.LocalPlayer
local teleporting = false
local hotkeyActive = false
local selectedKey = "T"
local keyConnection = nil

-- Depths
local depths = {-10000, -20000, -30000, -40000}

-- Teleport function
local function Teleport()
    if teleporting then 
        Rayfield:Notify({Title = "Error", Content = "Already teleporting!", Duration = 2})
        return
    end
    
    local char = player.Character
    if not char then 
        Rayfield:Notify({Title = "Error", Content = "No character found!", Duration = 2})
        return
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then 
        Rayfield:Notify({Title = "Error", Content = "No HumanoidRootPart!", Duration = 2})
        return
    end
    
    teleporting = true
    local originalPos = root.Position
    local originalCF = root.CFrame
    
    -- Teleport down through depths
    for i, depth in ipairs(depths) do
        char = player.Character
        if not char then break end
        root = char:FindFirstChild("HumanoidRootPart")
        if not root then break end
        
        local newPos = Vector3.new(originalPos.X, originalPos.Y + depth, originalPos.Z)
        root.CFrame = CFrame.new(newPos)
        
        if i < #depths then
            task.wait(0.75)
        end
    end
    
    task.wait(0.5)
    
    -- Return
    char = player.Character
    if char then
        root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = originalCF
            Rayfield:Notify({Title = "Success", Content = "Returned to surface!", Duration = 2})
