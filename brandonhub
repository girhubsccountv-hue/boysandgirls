-- Function to perform emote
local function performEmote()
    local player = game.Players.LocalPlayer
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            -- Load and play the emote animation
            local animation = Instance.new("Animation")
            animation.AnimationId = "rbxassetid://" .. emoteId
            local animTrack = humanoid:LoadAnimation(animation)
            animTrack:Play()
        end
    end
end

-- Function to start the emote loop
local function startEmoteLoop()
    emoteLoop = task.spawn(function()
        while isSpamming do
            performEmote()
            task.wait(3) -- Wait 3 seconds before next emote
        end
    end)
end

-- Function to toggle emote spam
local function toggleEmoteSpam()
    isSpamming = not isSpamming
    
    if isSpamming then
        startEmoteLoop()
        Rayfield:Notify({
            Title = "Emote Spam",
            Content = "Started! Playing emote every 3 seconds",
            Duration = 3,
        })
    else
        if emoteLoop then
            task.cancel(emoteLoop)
            emoteLoop = nil
        end
        Rayfield:Notify({
            Title = "Emote Spam",
            Content = "Stopped!",
            Duration = 3,
        })
    end
end

